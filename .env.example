# ---------------------------------------------------------------------------
# Frontend (Vite) environment variables
# Copy to .env (local) or .env.production (build) and adjust as needed.
# Only variables prefixed with VITE_ are exposed to the browser.
# ---------------------------------------------------------------------------

# Same-origin: the Express server serves the UI + API together, so a relative
# path is enough (no CORS, no hardcoded IP). This is the recommended value.
VITE_CONTACT_API_URL=/send-email

# Absolute fallback if the API is hosted separately from the UI:
# VITE_CONTACT_API_URL=http://117.217.120.58:8990/send-email
