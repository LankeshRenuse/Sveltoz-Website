# ---------------------------------------------------------------------------
# Backend (Express + Nodemailer) environment variables
# Copy to server/.env and fill in real SMTP credentials. Never commit .env.
# ---------------------------------------------------------------------------

# Port the server listens on (UI + /send-email API are served from here).
PORT=8990

# SMTP / mail settings used by Nodemailer to send the contact-form email.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Inbox that receives contact-form submissions.
HR_EMAIL=hr@sveltoz.com
