<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS config for hosting the Node backend (server.js) via iisnode.
  Requires the iisnode module installed on the server:
  https://github.com/Azure/iisnode
  Only needed if you host the backend on IIS instead of PM2.
-->
<configuration>
  <system.webServer>

    <!-- Route server.js through the iisnode handler. -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Let iisnode serve its debug endpoint. -->
        <rule name="iisnode-debug">
          <match url="^server.js\/debug[\/]?" />
        </rule>

        <!-- Send all traffic (UI + /send-email) to the Node app. -->
        <rule name="NodeApp">
          <match url="/*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Don't let IIS intercept Node's error responses. -->
    <httpErrors existingResponse="PassThrough" />

    <iisnode nodeProcessCommandLine="node.exe" watchedFiles="web.config;*.js" />

  </system.webServer>
</configuration>
